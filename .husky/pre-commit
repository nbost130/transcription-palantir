#!/bin/sh
# Pre-commit hook: Run quality checks before allowing commit

echo "🔨 Checking TypeScript compilation..."
npm run build || exit 1

echo "🎨 Checking code quality (Biome: linting & formatting)..."
npm run biome:check || exit 1

echo "📏 Checking file sizes (max 500 lines)..."
npm run check:size || exit 1

echo "✅ Running unit tests..."
npm run test src/utils/logger.test.ts src/services/file-watcher.test.ts src/workers/transcription-worker.test.ts || exit 1

echo "⚠️  Skipping integration tests (require Redis setup)"
echo "✨ All checks passed! Proceeding with commit..."
